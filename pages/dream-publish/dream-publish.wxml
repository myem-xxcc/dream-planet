<!-- pages/dream-publish/dream-publish.wxml -->
<!-- 职责：梦境发布/编辑页视图 —— 文字/语音切换、情绪选择、日期、提交 -->

<view class="publish-page deep-space-bg">

  <!-- 自定义导航栏 -->
  <view class="nav-bar">
    <view class="nav-back" bindtap="onTapBack">
      <text class="nav-back-icon">‹</text>
    </view>
    <text class="nav-title">{{mode === 'edit' ? '编辑梦境' : '记录梦境'}}</text>
    <view style="width:64rpx"></view>
  </view>

  <scroll-view scroll-y class="publish-scroll safe-bottom">

    <!-- 输入模式切换 -->
    <view class="mode-switch">
      <view
        class="mode-tab {{inputMode === 'text' ? 'mode-tab--active' : ''}}"
        data-mode="text"
        bindtap="onSwitchMode"
      >文字</view>
      <view
        class="mode-tab {{inputMode === 'voice' ? 'mode-tab--active' : ''}}"
        data-mode="voice"
        bindtap="onSwitchMode"
      >语音</view>
    </view>

    <!-- 标题输入 -->
    <view class="form-section glass-card">
      <text class="form-label">梦境标题</text>
      <input
        class="form-input form-input--title"
        placeholder="给这个梦起个名字..."
        placeholder-class="input-placeholder"
        value="{{title}}"
        bindinput="onTitleInput"
        maxlength="30"
      />
    </view>

    <!-- 文字正文 -->
    <view wx:if="{{inputMode === 'text'}}" class="form-section glass-card">
      <text class="form-label">梦境内容</text>
      <textarea
        class="form-textarea"
        placeholder="描述你的梦境..."
        placeholder-class="input-placeholder"
        value="{{content}}"
        bindinput="onContentInput"
        maxlength="2000"
        auto-height
      />
    </view>

    <!-- 语音录入 -->
    <view wx:else class="form-section glass-card voice-section">
      <text class="form-label">语音录入</text>

      <!-- 已有录音 -->
      <view wx:if="{{audioTempPath}}" class="record-result">
        <text class="record-done-icon">🎙</text>
        <text class="record-done-text">已录制 {{recordDuration}}″</text>
        <text class="record-redo" bindtap="onReRecord">重录</text>
      </view>

      <!-- 录音按钮 -->
      <view wx:else class="record-area">
        <view
          class="record-btn {{isRecording ? 'record-btn--active' : ''}}"
          bindtouchstart="onRecordStart"
          bindtouchend="onRecordStop"
        >
          <text class="record-btn-icon">{{isRecording ? '◉' : '⏺'}}</text>
          <text class="record-btn-label">{{isRecording ? '松开结束' : '长按录音'}}</text>
        </view>
        <text wx:if="{{isRecording}}" class="record-timer">{{recordDuration}}″</text>
        <text class="record-hint">松开即保存，最长 5 分钟</text>
      </view>
    </view>

    <!-- 情绪标签 -->
    <view class="form-section glass-card">
      <text class="form-label">梦境情绪</text>
      <view class="mood-grid">
        <view
          wx:for="{{moodOptions}}"
          wx:key="value"
          class="mood-item {{mood === item.value ? 'mood-item--active' : ''}}"
          data-value="{{item.value}}"
          bindtap="onMoodSelect"
        >
          <text class="mood-label">{{item.label}}</text>
        </view>
      </view>
    </view>

    <!-- 日期选择 -->
    <view class="form-section glass-card">
      <text class="form-label">梦境日期</text>
      <picker mode="date" value="{{date}}" bindchange="onDateChange">
        <view class="date-picker-row">
          <text class="date-value">{{date}}</text>
          <text class="date-arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 提交按钮 -->
    <view class="submit-area">
      <button
        class="btn-primary submit-btn"
        bindtap="onSubmit"
        loading="{{isSubmitting}}"
        disabled="{{isSubmitting}}"
      >
        {{isSubmitting ? '提交中...' : (mode === 'edit' ? '保存修改' : '发布梦境')}}
      </button>
    </view>

  </scroll-view>
</view>
