/* pages/dream-publish/dream-publish.wxss */
/* 职责：梦境发布/编辑页样式 —— 导航栏、表单卡片、模式切换、录音按钮、情绪选择 */

.publish-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* ===================== 导航栏 ===================== */
.nav-bar {
  display: flex;
  align-items: center;
  padding: 100rpx 32rpx 24rpx;
  background: rgba(13, 1, 32, 0.85);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-icon {
  font-size: 56rpx;
  color: #a78bfa;
  line-height: 1;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #e2d9f3;
  letter-spacing: 2rpx;
}

/* ===================== 滚动区域 ===================== */
.publish-scroll {
  flex: 1;
  padding: 24rpx 32rpx;
}

/* ===================== 模式切换 ===================== */
.mode-switch {
  display: flex;
  gap: 0;
  background: rgba(167, 139, 250, 0.1);
  border: 1rpx solid rgba(167, 139, 250, 0.2);
  border-radius: 9999rpx;
  padding: 6rpx;
  margin-bottom: 28rpx;
  width: 280rpx;
}

.mode-tab {
  flex: 1;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 9999rpx;
  font-size: 28rpx;
  color: #9d8ec4;
  transition: all 0.2s;
}

.mode-tab--active {
  background: linear-gradient(135deg, #7c5ccc, #a78bfa);
  color: #fff;
  font-weight: 600;
  box-shadow: 0 2rpx 12rpx rgba(167, 139, 250, 0.4);
}

/* ===================== 表单区块 ===================== */
.form-section {
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 24rpx;
  color: #9d8ec4;
  display: block;
  margin-bottom: 20rpx;
  letter-spacing: 1rpx;
}

/* 输入框 */
.form-input {
  width: 100%;
  background: transparent;
  border: none;
  border-bottom: 1rpx solid rgba(167, 139, 250, 0.25);
  padding: 12rpx 0;
  color: #e2d9f3;
  font-size: 30rpx;
}

.form-input--title {
  font-size: 36rpx;
  font-weight: 600;
}

.form-textarea {
  width: 100%;
  min-height: 240rpx;
  background: transparent;
  border: none;
  color: #c4b8e0;
  font-size: 30rpx;
  line-height: 1.8;
}

.input-placeholder {
  color: #5a4d7a;
}

/* ===================== 语音录入 ===================== */
.voice-section {}

.record-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  padding: 16rpx 0;
}

.record-btn {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: rgba(124, 92, 204, 0.2);
  border: 2rpx solid rgba(167, 139, 250, 0.4);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  transition: all 0.15s;
}

.record-btn--active {
  background: rgba(124, 92, 204, 0.5);
  border-color: #a78bfa;
  box-shadow: 0 0 32rpx rgba(167, 139, 250, 0.5);
  transform: scale(1.06);
}

.record-btn-icon {
  font-size: 56rpx;
  color: #a78bfa;
}

.record-btn-label {
  font-size: 22rpx;
  color: #9d8ec4;
}

.record-timer {
  font-size: 44rpx;
  color: #a78bfa;
  font-weight: 700;
}

.record-hint {
  font-size: 22rpx;
  color: #5a4d7a;
}

/* 已录制结果 */
.record-result {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
}

.record-done-icon {
  font-size: 40rpx;
}

.record-done-text {
  flex: 1;
  font-size: 28rpx;
  color: #e2d9f3;
}

.record-redo {
  font-size: 26rpx;
  color: #a78bfa;
  padding: 8rpx 24rpx;
  border: 1rpx solid rgba(167, 139, 250, 0.4);
  border-radius: 9999rpx;
}

/* ===================== 情绪选择 ===================== */
.mood-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.mood-item {
  padding: 14rpx 32rpx;
  border: 1rpx solid rgba(167, 139, 250, 0.3);
  border-radius: 9999rpx;
  background: rgba(167, 139, 250, 0.08);
  transition: all 0.15s;
}

.mood-item--active {
  background: linear-gradient(135deg, rgba(124, 92, 204, 0.6), rgba(167, 139, 250, 0.6));
  border-color: #a78bfa;
  box-shadow: 0 2rpx 12rpx rgba(167, 139, 250, 0.3);
}

.mood-label {
  font-size: 26rpx;
  color: #e2d9f3;
}

/* ===================== 日期选择 ===================== */
.date-picker-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 0;
}

.date-value {
  font-size: 30rpx;
  color: #e2d9f3;
}

.date-arrow {
  font-size: 36rpx;
  color: #9d8ec4;
}

/* ===================== 提交 ===================== */
.submit-area {
  padding: 16rpx 0 48rpx;
}

.submit-btn {
  width: 100%;
}
