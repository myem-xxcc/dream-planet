/* pages/publish/publish.wxss */
.container {
  min-height: 100vh;
  background: radial-gradient(ellipse at 50% 0%, #1a0f3a 0%, #0a0a1a 60%);
  padding: 40rpx 32rpx 120rpx;
}

.form-card {
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(160,120,255,0.15);
  border-radius: 28rpx;
  padding: 40rpx 36rpx;
  backdrop-filter: blur(10px);
}

/* 字段 */
.field {
  margin-bottom: 48rpx;
}
.label {
  display: block;
  font-size: 26rpx;
  color: #a78bfa;
  font-weight: 600;
  margin-bottom: 18rpx;
  letter-spacing: 1rpx;
}
.label-hint {
  font-size: 22rpx;
  color: #6b5fa0;
  font-weight: 400;
}
.input {
  width: 100%;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(160,120,255,0.2);
  border-radius: 16rpx;
  padding: 22rpx 24rpx;
  font-size: 28rpx;
  color: #e0d7ff;
  box-sizing: border-box;
}
.textarea {
  width: 100%;
  min-height: 200rpx;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(160,120,255,0.2);
  border-radius: 16rpx;
  padding: 22rpx 24rpx;
  font-size: 28rpx;
  color: #e0d7ff;
  box-sizing: border-box;
  line-height: 1.8;
}
.placeholder {
  color: #5a4f7a;
}
.char-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: #5a4f7a;
  margin-top: 10rpx;
}

/* 标签 */
.tags-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.tag {
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  border: 1rpx solid rgba(160,120,255,0.3);
  font-size: 24rpx;
  color: #9b8ec4;
  background: rgba(255,255,255,0.04);
  transition: all 0.2s;
}
.tag-active {
  background: rgba(120,80,200,0.35);
  border-color: #a78bfa;
  color: #e0d7ff;
}

/* 模式切换 */
.mode-switch {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}
.mode-btn {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 16rpx;
  border: 1rpx solid rgba(160,120,255,0.2);
  font-size: 26rpx;
  color: #9b8ec4;
  background: rgba(255,255,255,0.04);
}
.mode-active {
  background: rgba(120,80,200,0.3);
  border-color: #a78bfa;
  color: #e0d7ff;
  font-weight: 600;
}

/* 语音区域 */
.voice-area {
  min-height: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.03);
  border-radius: 16rpx;
  border: 1rpx dashed rgba(160,120,255,0.2);
  padding: 40rpx 20rpx;
}

.record-idle {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}
.record-btn {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #7b5ea7, #4a6fd4);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 30rpx rgba(120,80,200,0.5);
}
.record-icon { font-size: 44rpx; }
.record-hint { font-size: 24rpx; color: #6b5fa0; }

/* 录音中 */
.recording {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}
.pulse-ring {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(200,80,80,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  animation: pulse 1s ease-in-out infinite;
}
.pulse-dot {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: #f87171;
}
@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.15); }
}
.record-time { font-size: 28rpx; color: #f87171; }
.stop-btn {
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  background: rgba(248,113,113,0.2);
  border: 1rpx solid #f87171;
  font-size: 26rpx;
  color: #f87171;
}

/* 录音完成 */
.record-done {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}
.record-preview {
  width: 100%;
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.05);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  gap: 20rpx;
}
.preview-icon {
  font-size: 40rpx;
  color: #a78bfa;
  width: 60rpx;
  text-align: center;
}
.preview-info { flex: 1; }
.preview-title { display: block; font-size: 26rpx; color: #e0d7ff; }
.preview-dur { display: block; font-size: 22rpx; color: #6b5fa0; margin-top: 4rpx; }
.delete-icon { font-size: 32rpx; color: #6b5fa0; padding: 10rpx; }
.record-rerecord { font-size: 24rpx; color: #6b5fa0; text-decoration: underline; }

/* 提交按钮 */
.submit-wrap {
  margin-top: 48rpx;
  display: flex;
  justify-content: center;
}
.submit-btn {
  background: linear-gradient(135deg, #7b5ea7 0%, #4a6fd4 100%);
  border-radius: 60rpx;
  padding: 28rpx 120rpx;
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
  letter-spacing: 4rpx;
  box-shadow: 0 8rpx 32rpx rgba(120,80,200,0.45);
  text-align: center;
}
.submit-btn:active { opacity: 0.82; }
.submitting { opacity: 0.7; }
