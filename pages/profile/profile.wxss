/* pages/profile/profile.wxss */
/* 职责：个人中心页样式 —— 用户卡片、统计面板、梦境列表、退出按钮 */

.profile-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* ===================== 导航占位 ===================== */
.nav-placeholder {
  height: 100rpx;
  background: rgba(13, 1, 32, 0.6);
}

/* ===================== 滚动区域 ===================== */
.profile-scroll {
  flex: 1;
  padding: 32rpx;
}

/* ===================== 用户信息卡 ===================== */
.user-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 36rpx 40rpx;
  margin-bottom: 32rpx;
  gap: 24rpx;
}

.user-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(167, 139, 250, 0.5);
  box-shadow: 0 0 24rpx rgba(167, 139, 250, 0.3);
}

.user-nick-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.user-nick {
  font-size: 36rpx;
  font-weight: 700;
  color: #e2d9f3;
  letter-spacing: 1rpx;
}

.nick-edit-btn {
  font-size: 24rpx;
  color: #a78bfa;
  padding: 6rpx 20rpx;
  border: 1rpx solid rgba(167, 139, 250, 0.35);
  border-radius: 9999rpx;
}

/* 昵称编辑态 */
.user-nick-edit {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.nick-input {
  background: rgba(167, 139, 250, 0.1);
  border: 1rpx solid rgba(167, 139, 250, 0.35);
  border-radius: var(--radius-sm);
  padding: 16rpx 24rpx;
  color: #e2d9f3;
  font-size: 30rpx;
  text-align: center;
}

.nick-actions {
  display: flex;
  justify-content: center;
  gap: 40rpx;
}

.nick-cancel {
  font-size: 28rpx;
  color: #9d8ec4;
  padding: 12rpx 40rpx;
  border: 1rpx solid rgba(157, 142, 196, 0.3);
  border-radius: 9999rpx;
}

.nick-save {
  font-size: 28rpx;
  color: #fff;
  padding: 12rpx 40rpx;
  background: linear-gradient(135deg, #7c5ccc, #a78bfa);
  border-radius: 9999rpx;
}

/* ===================== 统计面板 ===================== */
.stats-panel {
  display: flex;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 16rpx;
  gap: 10rpx;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #a78bfa;
  line-height: 1;
}

.stat-mood {
  font-size: 30rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #9d8ec4;
}

/* ===================== 梦境列表 ===================== */
.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  color: #9d8ec4;
  letter-spacing: 1rpx;
}

.dream-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 48rpx;
}

.dream-list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
}

.dream-list-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex: 1;
  min-width: 0;
}

.dream-list-title {
  font-size: 30rpx;
  color: #e2d9f3;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.dream-list-date {
  font-size: 22rpx;
  color: #9d8ec4;
}

.dream-list-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.dream-list-arrow {
  font-size: 40rpx;
  color: #7c5ccc;
  line-height: 1;
}

/* ===================== 退出登录 ===================== */
.logout-area {
  padding: 16rpx 0 32rpx;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: rgba(239, 68, 68, 0.1);
  border: 1rpx solid rgba(239, 68, 68, 0.3);
  border-radius: 9999rpx;
  color: #f87171;
  font-size: 28rpx;
  letter-spacing: 2rpx;
}

.logout-btn::after {
  border: none;
}

.input-placeholder {
  color: #5a4d7a;
}
