/* pages/detail/detail.wxss */
.container {
  min-height: 100vh;
  background: radial-gradient(ellipse at 50% 10%, #1a0f3a 0%, #0a0a1a 55%);
  padding: 40rpx 40rpx 120rpx;
  position: relative;
  overflow: hidden;
}

/* 装饰环 */
.deco-top {
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  pointer-events: none;
}
.deco-ring {
  position: absolute;
  border-radius: 50%;
  border: 1rpx solid rgba(160,120,255,0.12);
}
.ring1 { width: 300rpx; height: 300rpx; top: 0; right: 0; }
.ring2 { width: 500rpx; height: 500rpx; top: -100rpx; right: -100rpx; }

/* 标题区 */
.title-section {
  padding-top: 30rpx;
  text-align: center;
  margin-bottom: 50rpx;
}
.dream-icon {
  display: block;
  font-size: 72rpx;
  margin-bottom: 20rpx;
}
.dream-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #e0d7ff;
  letter-spacing: 3rpx;
  text-shadow: 0 0 20rpx rgba(160,120,255,0.5);
  margin-bottom: 16rpx;
}
.dream-date {
  display: block;
  font-size: 24rpx;
  color: #6b5fa0;
  margin-bottom: 28rpx;
}

/* 标签 */
.tags-row {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 14rpx;
}
.tag {
  padding: 8rpx 24rpx;
  border-radius: 40rpx;
  font-size: 22rpx;
  background: rgba(120,80,200,0.2);
  border: 1rpx solid rgba(160,120,255,0.3);
  color: #c4b5fd;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(160,120,255,0.3), transparent);
  margin: 0 0 48rpx;
}

/* 文字内容 */
.content-section {
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(160,120,255,0.1);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 48rpx;
}
.content-text {
  font-size: 30rpx;
  color: #c4b5fd;
  line-height: 1.9;
  letter-spacing: 0.5rpx;
  white-space: pre-wrap;
}

/* 语音播放 */
.voice-section {
  margin-bottom: 48rpx;
}
.voice-player {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.05);
  border: 1rpx solid rgba(160,120,255,0.2);
  border-radius: 24rpx;
  padding: 30rpx 36rpx;
  gap: 24rpx;
}
.play-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #7b5ea7, #4a6fd4);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 20rpx rgba(120,80,200,0.5);
}
.playing {
  animation: spin-pulse 2s ease-in-out infinite;
}
@keyframes spin-pulse {
  0%, 100% { box-shadow: 0 4rpx 20rpx rgba(120,80,200,0.5); }
  50% { box-shadow: 0 4rpx 40rpx rgba(120,80,200,0.9); }
}
.play-icon { font-size: 34rpx; color: #fff; }
.voice-info { flex: 1; }
.voice-label { display: block; font-size: 28rpx; color: #e0d7ff; font-weight: 600; }
.voice-dur { display: block; font-size: 22rpx; color: #6b5fa0; margin-top: 6rpx; }

/* 声波动画 */
.wave-bars {
  display: flex;
  align-items: center;
  gap: 5rpx;
  height: 50rpx;
}
.bar {
  width: 6rpx;
  border-radius: 3rpx;
  background: #a78bfa;
}
.b1 { height: 20rpx; animation: wave 0.8s ease-in-out infinite; }
.b2 { height: 35rpx; animation: wave 0.8s ease-in-out infinite 0.1s; }
.b3 { height: 50rpx; animation: wave 0.8s ease-in-out infinite 0.2s; }
.b4 { height: 35rpx; animation: wave 0.8s ease-in-out infinite 0.3s; }
.b5 { height: 20rpx; animation: wave 0.8s ease-in-out infinite 0.4s; }
@keyframes wave {
  0%, 100% { transform: scaleY(0.5); }
  50% { transform: scaleY(1.3); }
}
.wave-idle .bar { animation: none; height: 16rpx !important; opacity: 0.4; }

/* 操作按钮 */
.actions {
  display: flex;
  justify-content: center;
  margin-top: 60rpx;
}
.action-btn {
  padding: 22rpx 80rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  text-align: center;
}
.btn-delete {
  border: 1rpx solid rgba(248,113,113,0.4);
  color: #f87171;
  background: rgba(248,113,113,0.08);
}
.btn-delete:active { opacity: 0.75; }

/* 404 */
.not-found {
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #6b5fa0;
  font-size: 30rpx;
}
