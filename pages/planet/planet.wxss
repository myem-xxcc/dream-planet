/* pages/planet/planet.wxss */
/* 职责：星球首页布局 —— canvas 全屏、气泡悬浮层、加载/空状态 */

.planet-page {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: #1a0533;
}

/* ===================== Canvas ===================== */
.planet-canvas {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

/* ===================== 气泡覆盖层 ===================== */
.bubbles-layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.dream-bubble {
  position: absolute;
  transform: translate(-50%, -50%);
  max-width: 200rpx;
  padding: 10rpx 22rpx;
  background: rgba(26, 5, 51, 0.65);
  border: 1rpx solid rgba(167, 139, 250, 0.5);
  border-radius: 9999rpx;
  backdrop-filter: blur(12rpx);
  -webkit-backdrop-filter: blur(12rpx);
  pointer-events: auto;
  /* 防止文字换行 */
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  box-shadow: 0 0 12rpx rgba(167, 139, 250, 0.2);
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}

.dream-bubble:active {
  transform: translate(-50%, -50%) scale(0.93);
  box-shadow: 0 0 20rpx rgba(167, 139, 250, 0.45);
}

.bubble-title {
  font-size: 22rpx;
  color: #e2d9f3;
  letter-spacing: 0.5rpx;
}

/* ===================== 顶部标题 ===================== */
.planet-header {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  padding: 100rpx 40rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  pointer-events: none;
}

.planet-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #e2d9f3;
  letter-spacing: 4rpx;
  text-shadow: 0 0 20rpx rgba(167, 139, 250, 0.6);
}

.planet-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #9d8ec4;
  letter-spacing: 1rpx;
}

/* ===================== 加载状态 ===================== */
.planet-loading {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  pointer-events: none;
}

.loading-dot {
  font-size: 48rpx;
  color: #a78bfa;
  animation: pulse 1.5s infinite;
}

.loading-text {
  font-size: 26rpx;
  color: #9d8ec4;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

/* ===================== 空状态 ===================== */
.planet-empty {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  pointer-events: none;
}

.empty-icon {
  font-size: 64rpx;
  color: #a78bfa;
  opacity: 0.6;
}

.empty-text {
  font-size: 30rpx;
  color: #e2d9f3;
}

.empty-hint {
  font-size: 24rpx;
  color: #9d8ec4;
}
