/* pages/login/login.wxss */
/* 职责：登录页样式 —— 全屏深空背景、星点装饰、Logo、按钮 */

.login-page {
  width: 100vw;
  min-height: 100vh;
  background: linear-gradient(160deg, #1a0533 0%, #0d0120 50%, #06010f 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

/* ===================== 星点背景 ===================== */
.star-layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.star {
  position: absolute;
  border-radius: 50%;
  background: #e2d9f3;
  animation: twinkle 3s infinite;
}

.star--s1  { width: 4rpx;  height: 4rpx;  top: 8%;  left: 12%; opacity: 0.7; animation-delay: 0s; }
.star--s2  { width: 6rpx;  height: 6rpx;  top: 15%; left: 78%; opacity: 0.5; animation-delay: 0.4s; }
.star--s3  { width: 3rpx;  height: 3rpx;  top: 30%; left: 35%; opacity: 0.8; animation-delay: 0.8s; }
.star--s4  { width: 5rpx;  height: 5rpx;  top: 45%; left: 90%; opacity: 0.4; animation-delay: 1.2s; }
.star--s5  { width: 4rpx;  height: 4rpx;  top: 60%; left: 20%; opacity: 0.6; animation-delay: 0.2s; }
.star--s6  { width: 3rpx;  height: 3rpx;  top: 72%; left: 60%; opacity: 0.9; animation-delay: 1.6s; }
.star--s7  { width: 5rpx;  height: 5rpx;  top: 85%; left: 42%; opacity: 0.5; animation-delay: 0.6s; }
.star--s8  { width: 4rpx;  height: 4rpx;  top: 22%; left: 55%; opacity: 0.7; animation-delay: 1.0s; }

@keyframes twinkle {
  0%, 100% { opacity: var(--star-opacity, 0.6); transform: scale(1); }
  50%       { opacity: 0.1;                     transform: scale(0.6); }
}

/* ===================== 中心内容 ===================== */
.login-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 60rpx;
  z-index: 1;
}

/* Logo */
.login-logo {
  width: 160rpx;
  height: 160rpx;
  background: radial-gradient(circle, rgba(124, 92, 204, 0.4) 0%, rgba(26, 5, 51, 0.2) 70%);
  border: 2rpx solid rgba(167, 139, 250, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  box-shadow: 0 0 48rpx rgba(167, 139, 250, 0.3),
              0 0 96rpx rgba(124, 92, 204, 0.15);
}

.logo-icon {
  font-size: 72rpx;
  color: #a78bfa;
  text-shadow: 0 0 20rpx rgba(167, 139, 250, 0.8);
}

/* 标题 */
.app-name {
  font-size: 64rpx;
  font-weight: 800;
  color: #e2d9f3;
  letter-spacing: 6rpx;
  margin-bottom: 20rpx;
  text-shadow: 0 0 32rpx rgba(167, 139, 250, 0.4);
}

.app-slogan {
  font-size: 28rpx;
  color: #9d8ec4;
  letter-spacing: 2rpx;
  margin-bottom: 60rpx;
}

/* 分隔 */
.login-divider {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 60rpx;
  width: 100%;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: rgba(167, 139, 250, 0.2);
}

.divider-text {
  font-size: 20rpx;
  color: rgba(167, 139, 250, 0.4);
}

/* 登录按钮 */
.login-btn {
  width: 600rpx;
  height: 100rpx;
  line-height: 100rpx;
  background: linear-gradient(135deg, #7c5ccc, #a78bfa);
  border-radius: 9999rpx;
  border: none;
  box-shadow: 0 6rpx 32rpx rgba(167, 139, 250, 0.4),
              0 2rpx 8rpx rgba(0, 0, 0, 0.3);
  margin-bottom: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-btn::after {
  border: none;
}

.login-btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 3rpx;
}

.login-tip {
  font-size: 22rpx;
  color: #5a4d7a;
  text-align: center;
}

/* ===================== 底部版权 ===================== */
.login-footer {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 0 0 40rpx;
  text-align: center;
}

.footer-text {
  font-size: 20rpx;
  color: #3d2b5a;
  letter-spacing: 1rpx;
}
